# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=https://swavleba.ge

# Keepz Payment Gateway
KEEPZ_BASE_URL=https://gateway.keepz.me/ecommerce-service
KEEPZ_INTEGRATOR_ID=your-integrator-id
KEEPZ_RECEIVER_ID=your-receiver-id
KEEPZ_RSA_PUBLIC_KEY=your-rsa-public-key
MY_RSA_PRIVATE_KEY=your-rsa-private-key
KEEPZ_ALLOWED_IPS=# comma-separated Keepz callback IPs

# Team Access Key (for coming-soon bypass)
TEAM_ACCESS_KEY=your-secret-key-here

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=# Get from Upstash console
UPSTASH_REDIS_REST_TOKEN=# Get from Upstash console

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
